msgstr "横から:"

msgid "Hide button on mobile (768px and below)"
msgstr "モバイルではボタンを非表示にする（768px以下）"

msgid "Check this if the button interferes with fixed footer menus on mobile."
msgstr "スマホ画面で下部固定メニュー等と干渉する場合にチェックしてください。"

msgid "Size & Position (Desktop)"
msgstr "サイズ・位置 (PC)"

msgid "Arrow Shape"
msgstr "矢印の形状"

msgid "Display Trigger"
msgstr "表示タイミング"

msgid "px scrolled to show (default: 100)"
msgstr "px スクロールしたら表示 (標準: 100)"

msgid "Scroll Speed"
msgstr "スクロール速度"

msgid "Fast (0.2s)"
msgstr "高速（0.2秒）"

msgid "Slightly Fast (0.4s)"
msgstr "やや速い（0.4秒）"

msgid "Normal (0.6s)"
msgstr "標準（0.6秒）"

msgid "Slow (1s)"
msgstr "ゆっくり（1秒）"

msgid "Very Slow (1.5s)"
msgstr "とてもゆっくり（1.5秒）"

msgid "Animation speed when scrolling back to top."
msgstr "ボタンクリック時にトップへ戻るアニメーションの速度です。"

msgid "Z-index"
msgstr "Z-index"

msgid "(default: 99)"
msgstr "(標準: 99)"

msgid "Exclude Pages"
msgstr "非表示にするページ（除外設定）"

msgid "e.g. 123, about, contact (use \"front\" for front page)"
msgstr "例: 123, about, contact （トップページ除外は front）"

msgid "Enter <strong>page IDs</strong> or <strong>slugs</strong> separated by commas to hide the button on those pages."
msgstr "ボタンを非表示にしたいページの <strong>ページID</strong> または <strong>スラッグ</strong> をカンマ区切りで入力してください。"

msgid "To exclude the front page, enter <code>front</code>."
msgstr "トップページを除外する場合は <code>front</code> と入力してください。"

msgid "Live Preview"
msgstr "ライブプレビュー"

msgid "Changes are reflected in real time."
msgstr "※設定を変更するとリアルタイムで反映されます"

msgid "Save Settings"
msgstr "設定を保存する"

msgid "If changes are not reflected"
msgstr "反映されない場合"

# translators: %s: "cache plugin" in bold
msgid "If the button does not appear after saving, please clear your %s or server cache."
msgstr "設定を保存してもサイトにボタンが表示されない場合は、ご利用中の%sやサーバーのキャッシュをクリアしてください。"

msgid "cache plugin"
msgstr "キャッシュプラグイン"

msgid "Reset to Defaults (My Colors preserved)"
msgstr "基本設定のみデフォルトに戻す（マイ・カラーは残す）"

msgid "Reset all settings to defaults? Your My Colors will be preserved."
msgstr "マイ・カラーセット以外の設定を初期値に戻しますか？"

msgid "Export Code for External Sites"
msgstr "外部サイト・LP用 コード書き出し"

# translators: %s: </body> tag in code format
msgid "The code below reflects your saved settings. Paste it just before the %s tag in non-WordPress static HTML pages."
msgstr "保存されている設定が反映されたコードです。WordPress以外の静的HTMLの%sタグの直前に貼り付けられます。"

# translators: %s: Slot number
msgid "Save current colors and opacity to slot %s?"
msgstr "現在の「配色と透明度」をスロット %s に保存しますか？"

# translators: %s: Slot number
msgid "Clear slot %s and remove its settings?"
msgstr "スロット %s の設定を削除して空にしますか？"

msgid "Back to top"
msgstr "ページトップへ戻る"
